{
  "entities": {
    "Trade": {
      "title": "Trade Signal",
      "description": "A signal generated by the AI for a specific asset.",
      "type": "object",
      "properties": {
        "asset": { "type": "string" },
        "action": { "type": "string", "enum": ["BUY", "SELL", "HOLD"] },
        "confidence": { "type": "number" },
        "entry": { "type": "string" },
        "stop_loss": { "type": "number" },
        "take_profit_1": { "type": "number" },
        "take_profit_2": { "type": "number" },
        "rr_ratio": { "type": "string" },
        "ai_reasoning": { "type": "string" },
        "timestamp": { "type": "number" },
        "status": { "type": "string", "enum": ["PENDING", "WON", "LOST"] },
        "userId": { "type": "string" }
      },
      "required": ["asset", "action", "confidence", "entry", "stop_loss", "take_profit_1", "take_profit_2", "rr_ratio", "ai_reasoning", "timestamp", "userId"]
    }
  },
  "firestore": {
    "/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Collection of trade signals generated by the AI."
    }
  }
}
